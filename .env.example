# WebChat Environment Configuration
# Copy this file to .env and update the values

# Server Configuration
NODE_ENV=production
PORT=3000
HOST=0.0.0.0

# Session Secret (generate a strong random string for production)
# You can use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=webchat-secret-change-this-in-production

# Database Path (relative to backend directory)
DB_PATH=./chat.db

# Upload Configuration
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=52428800

# CORS Configuration (comma-separated origins if needed)
# CORS_ORIGIN=http://yourdomain.com,https://www.yourdomain.com

# SSL/TLS (if not using reverse proxy)
# HTTPS_ENABLED=false
# HTTPS_CERT_PATH=/path/to/cert.pem
# HTTPS_KEY_PATH=/path/to/key.pem
