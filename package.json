{
  "name": "webchat",
  "version": "1.0.0",
  "description": "Mobile-first 1-on-1 web chat application",
  "main": "backend/server.js",
  "scripts": {
    "start": "node backend/server.js",
    "dev": "NODE_ENV=development node backend/server.js",
    "prod": "NODE_ENV=production node backend/server.js",
    "install:prod": "npm ci --only=production",
    "postinstall": "node -e \"console.log('WebChat installed successfully!')\"",
    "docker:build": "docker build -t webchat .",
    "docker:run": "docker run -d -p 3000:3000 --name webchat webchat",
    "docker:stop": "docker stop webchat && docker rm webchat",
    "docker:logs": "docker logs -f webchat",
    "compose:up": "docker-compose up -d --build",
    "compose:down": "docker-compose down",
    "compose:logs": "docker-compose logs -f",
    "compose:restart": "docker-compose restart"
  },
  "keywords": [
    "chat",
    "websocket",
    "real-time"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "better-sqlite3": "^11.8.1",
    "cors": "^2.8.6",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-session": "^1.18.1",
    "ffmpeg-static": "^5.3.0",
    "fluent-ffmpeg": "^2.1.3",
    "multer": "^1.4.5-lts.1",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.3",
    "sql.js": "^1.14.1"
  }
}
